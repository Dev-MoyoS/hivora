rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /resources/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /posts/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /support/{allPaths=**} {
      allow write: if true;
      allow read: if false;
    }
  }
}
