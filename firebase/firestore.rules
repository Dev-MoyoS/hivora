rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isSignedIn() && userDoc().role == role;
    }

    function isModerator() {
      return isSignedIn() && (userDoc().isModerator == true || userDoc().role == 'moderator' || userDoc().role == 'admin');
    }

    function isAdmin() {
      return isSignedIn() && (userDoc().isAdmin == true || userDoc().role == 'admin');
    }

    // ── Users ──
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // ── Public read collections (visitor mode) ──
    match /posts/{postId} {
      allow read: if true;
      allow create: if isSignedIn() && hasRole('participant') || hasRole('creator') || hasRole('moderator') || hasRole('admin');
      allow update: if isSignedIn() && (resource.data.authorId == request.auth.uid || isModerator());
      allow delete: if isModerator() || isAdmin();
    }

    match /replies/{replyId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (resource.data.authorId == request.auth.uid || isModerator());
    }

    match /resources/{resourceId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isModerator() || isAdmin();
    }

    match /study_groups/{groupId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isModerator() || isAdmin();
    }

    match /talent_offers/{offerId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /courses/{courseId} {
      allow read: if true;
      allow write: if isSignedIn() && (hasRole('creator') || isAdmin());
    }

    match /analytics/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // ── Authenticated-only ──
    match /votes/{voteId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    match /bookmarks/{bookmarkId} {
      allow read, write: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
    }

    match /notifications/{notificationId} {
      allow read: if isSignedIn() && resource.data.recipientId == request.auth.uid;
      allow write: if false;
    }

    match /group_chats/{chatId} {
      allow read, write: if isSignedIn();
    }

    match /voice_rooms/{roomId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /private_chats/{chatId} {
      allow read, write: if isSignedIn();
    }

    match /trust_rooms/{roomId}/messages/{messageId} {
      allow read, write: if isSignedIn();
    }

    match /journal_entries/{entryId} {
      allow read, write: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
    }

    // ── Moderation ──
    match /reports/{reportId} {
      allow create: if isSignedIn();
      allow read, update: if isModerator() || isAdmin();
    }

    match /moderation_reports/{reportId} {
      allow create: if isSignedIn();
      allow read, update: if isModerator() || isAdmin();
    }

    // ── Listening Chamber (encrypted, code-only) ──
    match /support_requests/{requestId} {
      allow create: if true;
      allow read: if isAdmin();
      allow update: if isAdmin();
    }

    match /anonymous_codes/{codeId} {
      allow create: if true;
      allow read: if false;
    }
  }
}
